rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /game_likes/{gameId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Tic-Tac-Toe online: one doc per match, minimal reads (one listener) and writes (one per move/join)
    match /tictactoe_matches/{matchId} {
      allow read: if request.auth != null && (
        resource.data.status == 'waiting'
        || resource.data.creatorId == request.auth.uid
        || resource.data.opponentId == request.auth.uid
      );
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.creatorId == request.auth.uid
        || resource.data.opponentId == request.auth.uid
        || (resource.data.status == 'waiting' && resource.data.opponentId == null)
      );
      allow delete: if request.auth != null && resource.data.creatorId == request.auth.uid;
    }

    // Neon Dash: community and personal levels (Play Levels → Built-in / My Levels / Community)
    match /custom_levels/{levelId} {
      // Anyone can read public levels; authors can read their own (including private)
      allow read: if resource.data.get('isPublic', true) == true
        || (request.auth != null && resource.data.authorId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null;

      match /friends/{friendId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == friendId);
      }

      match /friend_requests/{requestId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == requestId;
      }

      match /achievements/{achievementId} {
        allow write: if request.auth != null && request.auth.uid == userId;
        allow read: if request.auth != null && (
          request.auth.uid == userId
          || exists(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid))
        );
      }

      match /progress/{gameId} {
        allow write: if request.auth != null && request.auth.uid == userId;
        allow read: if request.auth != null && (
          request.auth.uid == userId
          || exists(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid))
        );
      }
    }

    // Leaderboards
    match /leaderboards/{gameId} {
      allow read: if true;
      
      match /alltime/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /monthly/{docId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == request.resource.data.uid;
      }
      
      match /daily/{docId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == request.resource.data.uid;
      }
    }
  }
}
